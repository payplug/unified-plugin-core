{
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "/^(PRE|SMP)-\\d+: .+/"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Branch\\Action\\EnsureNaming",
                "options": {
                    "regex": "/^((feature|fix|hotfix|refactor)\\/(PRE|SMP)-\\d+[a-zA-Z0-9_]*|(release|patch)\\/\\d+\\.\\d+\\.\\d+)$/"
                }
            },
            {
                "action": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --diff",
                "options": {}
            }
        ]
    }
}
